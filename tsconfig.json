{
	"exclude": ["functions"],
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"allowJs": true,
		"strict": true,
		"noEmit": true,
		"types": ["vinxi/types/client", "@testing-library/jest-dom"],
		"isolatedModules": true,
		"paths": {
			"~/*": ["./src/*"]
		},
		"skipLibCheck": true
	}
}
